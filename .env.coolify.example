# Paste these into Coolify application environment variables.
GIGI_ENV=production
GIGI_HTTP_ADDR=:8080
GIGI_DATABASE_URL=postgres://gigi:<same-as-postgres-password>@db:5432/gigi?sslmode=disable

POSTGRES_DB=gigi
POSTGRES_USER=gigi
POSTGRES_PASSWORD=<secure-password>

GIGI_DISCORD_ENABLED=false
GIGI_DISCORD_SYNC_COMMANDS=false
GIGI_DISCORD_GUILD_ID=
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

OPENAI_API_KEY=
