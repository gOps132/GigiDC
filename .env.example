NODE_ENV=development
LOG_LEVEL=info
PORT=8080

# Discord application credentials
DISCORD_TOKEN=replace-with-your-discord-bot-token
DISCORD_CLIENT_ID=replace-with-your-discord-application-client-id

# Optional but strongly recommended for fast local slash-command registration
DISCORD_GUILD_ID=replace-with-your-discord-server-id

# Optional v1 primary server for DM guild-wide retrieval checks
PRIMARY_GUILD_ID=replace-with-your-primary-discord-server-id

# Optional startup behavior
REGISTER_COMMANDS_ON_STARTUP=true

# Supabase server-side credentials
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-supabase-service-role-key

# OpenAI credentials for DM reasoning and embeddings
OPENAI_API_KEY=replace-with-your-openai-api-key
OPENAI_RESPONSE_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional 32-byte base64 or hex key for encrypted sensitive-data records
SENSITIVE_DATA_ENCRYPTION_KEY=replace-with-your-32-byte-base64-or-hex-key
