GIGI_ENV=development
GIGI_HTTP_ADDR=:8080
GIGI_DATABASE_URL=postgres://db:5432/gigi?sslmode=disable
GIGI_MIGRATIONS_DIR=/app/db/migrations

# Enable only when Discord credentials are configured.
GIGI_DISCORD_ENABLED=false
GIGI_DISCORD_SYNC_COMMANDS=false
GIGI_DISCORD_GUILD_ID=
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# LLM provider credential sealing. Required for /llm provider add and rotate.
# Generate with: openssl rand -base64 32
# Provider API keys are entered through /llm modals, not OPENAI_API_KEY.
# GIGI_LLM_SECRET_KEY_BASE64=
# GIGI_LLM_SECRET_KEY_ID=local-v1

# Web search provider. Defaults to duckduckgo unless BRAVE_SEARCH_API_KEY or SEARXNG_BASE_URL is set.
# Provider: duckduckgo, brave, or searxng. Fallback: blank, duckduckgo, or searxng.
# Local Docker Compose defaults to searxng at http://searxng:8080.
# GIGI_WEB_SEARCH_PROVIDER=searxng
# GIGI_WEB_SEARCH_FALLBACK=duckduckgo
# BRAVE_SEARCH_API_KEY=
# SEARXNG_BASE_URL=http://searxng:8080
# SEARXNG_PORT=8081
# SEARXNG_PUBLIC_URL=http://127.0.0.1:8081/
# SEARXNG_SECRET=change-me-in-production

# PostgreSQL container defaults for Docker Compose.
POSTGRES_DB=gigi
POSTGRES_USER=gigi
POSTGRES_PASSWORD=change-me
