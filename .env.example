NODE_ENV=development
LOG_LEVEL=info
PORT=8080

# Discord application credentials
DISCORD_TOKEN=replace-with-your-discord-bot-token
DISCORD_CLIENT_ID=replace-with-your-discord-application-client-id

# Optional but strongly recommended for fast local command registration
DISCORD_GUILD_ID=replace-with-your-discord-server-id

# Supabase server-side credentials
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-supabase-service-role-key

# Public base URL where this bot can receive webhook callbacks
BOT_PUBLIC_BASE_URL=https://your-bot-host.example.com

# Clawbot backend connection
CLAWBOT_BASE_URL=http://your-clawbot-ip-or-host:3000
CLAWBOT_API_KEY=replace-with-your-clawbot-api-key

# Optional dedicated secret for Clawbot webhook callbacks.
# If omitted in code setup, use the same value as CLAWBOT_API_KEY in your Clawbot config.
CLAWBOT_WEBHOOK_SECRET=replace-with-your-clawbot-webhook-secret

# Override these only if your Clawbot uses different endpoints
CLAWBOT_JOB_PATH=/api/v1/jobs
CLAWBOT_INGEST_PATH=/api/v1/ingest/discord-message
