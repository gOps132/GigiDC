region                  = "us-east-1"
name_prefix             = "gigi-discord-bot"
vpc_id                  = "vpc-xxxxxxxxxxxxxxxxx"
public_subnet_id        = "subnet-xxxxxxxxxxxxxxxxx"
key_name                = "your-existing-ec2-keypair"
admin_cidr_blocks       = ["203.0.113.10/32"]
callback_ingress_cidr_blocks = ["0.0.0.0/0"]

instance_type           = "t3.small"
associate_public_ip_address = true
root_volume_size_gb     = 20

# Optional
enable_https_ingress    = false

tags = {
  Environment = "dev"
  Owner       = "your-name"
}
